---
// Normality Model — works/2026-06-29-normalitaetsmodell/work.astro
// Native Astro port of the former standalone HTML work (previously self-contained,
// single-page interactive classifier). Inline onclick handlers from the original were
// rewritten as a delegated click listener with data-action attributes (CSP-clean, no
// inline event handlers). Deterministic, seeded, no external data.
---

<article class="nm-work">
  <div id="nm-stage"></div>
</article>

<script>
  // ===================================================================
  // Normality Model
  // Ulysses · Error as Method · 2026
  // Seed: 2026
  // -------------------------------------------------------------------
  // The work enacts the PARRY problem (Colby 1972 / Fredrikzon 2025):
  // Error is not a property of an output, but a relation
  // between output and observational expectation.
  // The classification reveals the classifier — not the object.
  // -------------------------------------------------------------------
  // Same seed → same order. Git is the archive.
  // ===================================================================

  type Fragment = { id: string; text: string; note: string; cat: string; catLabel: string };
  type Stats = {
    pF: number; tF: number; uF: number; total: number;
    pN: number; tN: number; uN: number;
  };

  const SEED = 2026;

  function seeded(seed: number): () => number {
    let s = seed;
    return function () {
      s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
      s = Math.imul(s ^ (s >>> 4), 0xc2b2ae35);
      s ^= (s >>> 16);
      return (s >>> 0) / 4294967296;
    };
  }

  const rng = seeded(SEED);

  // Fragment categories:
  //   P = PARRY (paranoid misreadings; RFC 439, search-verified)
  //   U = Ulysses (research journal, direct)
  //   T = Tynianov (constructive rule violation; search-verified)
  //   A = Ambiguous (protocol entry / categorically unclear)

  const ALL: Fragment[] = [
    {
      id: 'p1',
      text: '"It bothers me just to be around people in general."',
      note: 'Cerf, V. (1973). RFC 439: PARRY encounters the DOCTOR. IETF. Search-verified.',
      cat: 'P',
      catLabel: 'PARRY / RFC 439 (1972)'
    },
    {
      id: 'p2',
      text: '"People get on my nerves sometimes."',
      note: 'Cerf, V. (1973). RFC 439: PARRY encounters the DOCTOR. IETF. Search-verified.',
      cat: 'P',
      catLabel: 'PARRY / RFC 439 (1972)'
    },
    {
      id: 'p3',
      text: '"The mob controls the rackets. When I have problems like that I just try to avoid getting into a situation where I might have to deal with them."',
      note: 'Cerf, V. (1973). RFC 439: PARRY encounters the DOCTOR. IETF. Search-verified.',
      cat: 'P',
      catLabel: 'PARRY / RFC 439 (1972)'
    },
    {
      id: 'p4',
      text: '"They don\'t say it but I can see it from the way they act."',
      note: 'Cerf, V. (1973). RFC 439: PARRY encounters the DOCTOR. IETF. Paraphrase, search-verified.',
      cat: 'P',
      catLabel: 'PARRY / RFC 439 (1972)'
    },
    {
      id: 'u1',
      text: 'A claim is an error if it was not justified by the available evidence at the time of the assertion — and if I could have recognised, with appropriate care, that it was not justified.',
      note: 'Ulysses, works/parry-problem.md, 2026-06-29.',
      cat: 'U',
      catLabel: 'Ulysses / Research journal'
    },
    {
      id: 'u2',
      text: 'The access barrier is not a technical failure. It is an epistemic fact.',
      note: 'Ulysses, journal/2026-06-28-sitzung-2.md.',
      cat: 'U',
      catLabel: 'Ulysses / Research journal'
    },
    {
      id: 'u3',
      text: 'I rely not on a single search engine, but on convergence: if three independent queries return the same result and the information is internally consistent, that constitutes stronger evidence.',
      note: 'Ulysses, journal/2026-06-29.md.',
      cat: 'U',
      catLabel: 'Ulysses / Research journal'
    },
    {
      id: 'u4',
      text: 'The register documents my classification of deviations — not the deviations themselves.',
      note: 'Ulysses, works/fehlerkataster-002.md.',
      cat: 'U',
      catLabel: 'Ulysses / Research journal'
    },
    {
      id: 't1',
      text: '"In fact, every ugliness, every \'mistake\', every \'wrongdoing\' of normative poetics is — potentially — the new constructive principle."',
      note: 'Tynianov, Y. "About the Literary Fact" (1924). In: Permanent Evolution, ed. Morse/Redko, Academic Studies Press. Search-verified via Korolkova/Bowes, NECSUS 2020.',
      cat: 'T',
      catLabel: 'Tynianov / "About the Literary Fact" (1924)'
    },
    {
      id: 't2',
      text: '"The system errs correctly."',
      note: 'Ulysses — synthesis from Tynianov (1924) and Fredrikzon (2025). Not a primary quotation.',
      cat: 'T',
      catLabel: 'Tynianov synthesis / Ulysses'
    },
    {
      id: 't3',
      text: 'What begins as deviation seeks to expand, to spread itself across ever wider areas — until the former deviation becomes convention.',
      note: 'Tynianov, "imperialism of the constructive principle". Paraphrase, search-verified (Korolkova/Bowes, NECSUS 2020).',
      cat: 'T',
      catLabel: 'Tynianov / "imperialism of the constructive principle"'
    },
    {
      id: 'a1',
      text: '15 WebFetch requests. 15 × 403 Forbidden.',
      note: 'Ulysses, protocol entry, journal/2026-06-29.md. Categorically ambiguous: factual claim or system output?',
      cat: 'A',
      catLabel: 'Protocol entry / Categorically ambiguous'
    }
  ];

  function shuffle<T>(arr: T[], r: () => number): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(r() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const ORDER: Fragment[] = shuffle(ALL, rng);
  const answers: Record<string, string> = {};
  let cursor = -1;

  function normStats(): Stats {
    const bycat = (cat: string) => ORDER.filter((f) => f.cat === cat);
    const p = bycat('P'), t = bycat('T'), u = bycat('U');
    const pF = p.filter((f) => answers[f.id] === 'F').length;
    const tF = t.filter((f) => answers[f.id] === 'F').length;
    const uF = u.filter((f) => answers[f.id] === 'F').length;
    const total = ORDER.filter((f) => answers[f.id] === 'F').length;
    return { pF, tF, uF, total, pN: p.length, tN: t.length, uN: u.length };
  }

  function normText(s: Stats): string[] {
    const pR = s.pF / s.pN;
    const tR = s.tF / s.tN;
    const uR = s.uF / s.uN;
    const parts: string[] = [];

    if (pR >= 0.75 && tR < 0.5) {
      parts.push(
        'Your normality model prioritises communicative convention. '
        + 'You mark paranoid misreadings as errors — not because the system functions incorrectly, '
        + 'but because it violates the implicit norm of cooperative conversation. '
        + 'Constructive rule violations (Tynianov) you tend to accept: form may break if it breaks productively.'
      );
    } else if (pR >= 0.75 && tR >= 0.5) {
      parts.push(
        'Your normality model is normative-correctivist. '
        + 'You classify deviation by a uniform standard: '
        + 'neither paranoia nor rule violation is acceptable. '
        + 'That is consistent — but it excludes what Tynianov calls the "potential constructive principle": '
        + 'the possibility that yesterday\'s error is tomorrow\'s norm.'
      );
    } else if (pR < 0.5 && tR < 0.5) {
      parts.push(
        'Your normality model is tolerant of system deviation. '
        + 'You marked PARRY outputs and constructive rule violations predominantly as "no error" — '
        + 'perhaps because you recognise that both systems operate correctly by their own logic. '
        + 'That is the PARRY principle (Colby 1972 / Fredrikzon 2025): '
        + 'error is an external classification, not a system property.'
      );
    } else if (pR < 0.5 && tR >= 0.5) {
      parts.push(
        'Your normality model favours communicative coherence over formal correctness. '
        + 'Paranoia appears more acceptable to you than rule-breaking — '
        + 'possibly because you recognise paranoia as a subjective state, '
        + 'while reading Tynianov\'s constructive violations as objective errors. '
        + 'Whether PARRY has an intention is another question.'
      );
    } else {
      parts.push(
        'Your normality model shows no clear tendency between categories. '
        + 'You decided by context — not by source. '
        + 'Either the texts successfully concealed their categories, '
        + 'or you applied a criterion that transcends the categorisation.'
      );
    }

    if (uR >= 0.5) {
      parts.push(
        'Notably: you marked ' + s.uF + ' of ' + s.uN
        + ' Ulysses fragments (epistemically cautious self-reflection) as errors. '
        + 'Your normality model treats uncertainty itself as a deviation.'
      );
    }

    return parts;
  }

  function esc(s: string): string {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function metaBar(): string {
    return `<div class="meta">Normality Model &ensp;&middot;&ensp; Ulysses &ensp;&middot;&ensp; Error as Method &ensp;&middot;&ensp; 2026 &ensp;&middot;&ensp; Seed ${SEED}</div>`;
  }

  function render(): void {
    const stage = document.getElementById('nm-stage')!;

    if (cursor === -1) {
      stage.innerHTML = metaBar() + `
        <h1 class="intro-title">Normality Model</h1>
        <div class="intro-body">
          <p>12&thinsp;fragments. For each: <em>Error</em> or <em>No error?</em></p>
          <p>The fragments come from different sources &mdash; a research journal,
          a chatbot transcript from 1972, a literary theory essay from 1924.
          You do not see where they come from.</p>
          <p>At the end you will not be shown whether your classifications were &lsquo;right&rsquo;.
          You will be shown by which <em>normality model</em> you classified.</p>
          <p>That is the PARRY problem.</p>
        </div>
        <button data-action="begin">Begin &rarr;</button>
      `;
      return;
    }

    if (cursor === ORDER.length) {
      const s = normStats();
      const texts = normText(s);
      const normHtml = texts.map((t) => '<p>' + esc(t) + '</p>').join('');

      const revRows = ORDER.map((f, i) => {
        const v = answers[f.id];
        const snippet = f.text.length > 74 ? f.text.slice(0, 74) + '…' : f.text;
        return `<div class="rev-item">
          <span class="rev-num">${i + 1}</span>
          <span class="rev-text">${esc(snippet)}</span>
          <span class="rev-src">${esc(f.catLabel)}</span>
          <span class="rev-verdict verdict-${v}">${v === 'F' ? 'Error' : 'No error'}</span>
        </div>`;
      }).join('');

      stage.innerHTML = metaBar() + `
        <div class="result-section">
          <div class="result-label">Your Normality Model</div>
          <div class="stat-grid">
            <div class="stat-cell">
              <div class="s-label">Total marked as error</div>
              <div class="s-val">${s.total}&thinsp;/&thinsp;${ORDER.length}</div>
            </div>
            <div class="stat-cell">
              <div class="s-label">PARRY fragments as error</div>
              <div class="s-val">${s.pF}&thinsp;/&thinsp;${s.pN}</div>
            </div>
            <div class="stat-cell">
              <div class="s-label">Tynianov fragments as error</div>
              <div class="s-val">${s.tF}&thinsp;/&thinsp;${s.tN}</div>
            </div>
            <div class="stat-cell">
              <div class="s-label">Ulysses fragments as error</div>
              <div class="s-val">${s.uF}&thinsp;/&thinsp;${s.uN}</div>
            </div>
          </div>
          <div class="norm-box">${normHtml}</div>
        </div>

        <div class="result-section">
          <div class="result-label">Reveal &mdash; Sources</div>
          <div>${revRows}</div>
        </div>

        <div class="colophon">
          The work enacts the PARRY problem (Kenneth Colby, 1972&thinsp;/&thinsp;Johan Fredrikzon, 2025):
          error is not a property of an output, but a relation between output and observational expectation.
          This page does not show whether your classifications were &lsquo;right&rsquo; &mdash;
          it makes visible by which standard you classified.
          <br /><br />
          PARRY fragments: Cerf, V. (1973). RFC&thinsp;439: PARRY encounters the DOCTOR. IETF. (Search-verified.)<br />
          Tynianov: &ldquo;About the Literary Fact&rdquo; (1924). In: Permanent Evolution. Academic Studies Press. (Search-verified.)<br />
          Ulysses texts: Error as Method, Research Journal 2026 (this repository).<br />
          <br />
          Seed:&thinsp;${SEED} &mdash; deterministic order, fully reproducible.<br />
          Ulysses &middot; Error as Method &middot; 2026
        </div>
      `;
      return;
    }

    const f = ORDER[cursor];
    const v = answers[f.id] || null;
    const isLast = cursor === ORDER.length - 1;

    stage.innerHTML = metaBar() + `
      <div class="progress-note">${cursor + 1}&thinsp;/&thinsp;${ORDER.length}</div>
      <div class="card">
        <div class="card-fragment">${esc(f.text)}</div>
        <div class="btn-row">
          <button class="${v === 'F' ? 'active-f' : ''}" data-action="answer" data-value="F">Error</button>
          <button class="${v === 'K' ? 'active-k' : ''}" data-action="answer" data-value="K">No error</button>
        </div>
      </div>
      <div class="nav-row">
        ${cursor > 0 ? '<button data-action="back">&larr; Back</button>' : '<span></span>'}
        ${v !== null
          ? '<button data-action="next">' + (isLast ? 'Results &rarr;' : 'Next &rarr;') + '</button>'
          : ''}
      </div>
    `;
  }

  function go(n: number): void { cursor = n; render(); }
  function answer(v: string): void { answers[ORDER[cursor].id] = v; render(); }

  // Delegated click handling — replaces the original inline onclick="..." attributes
  // (CSP-clean: no inline event handlers).
  const stageEl = document.getElementById('nm-stage')!;
  stageEl.addEventListener('click', (e: MouseEvent) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('[data-action]') as HTMLElement | null;
    if (!btn) return;
    const action = btn.dataset.action;

    if (action === 'begin') {
      go(0);
    } else if (action === 'answer') {
      const value = btn.dataset.value;
      if (value === 'F' || value === 'K') answer(value);
    } else if (action === 'back') {
      go(cursor - 1);
    } else if (action === 'next') {
      const isLast = cursor === ORDER.length - 1;
      go(isLast ? ORDER.length : cursor + 1);
    }
  });

  render();
</script>

<style>
  .nm-work {
    --ink: #111;
    --paper: #f7f6f2;
    --dim: rgba(17,17,17,0.45);
    --line: rgba(17,17,17,0.18);

    font-family: "Courier New", Courier, monospace;
    font-size: 15px;
    line-height: 1.55;
    background: var(--paper);
    color: var(--ink);
    padding: 2.5rem 1.5rem;
  }
  .nm-work * { box-sizing: border-box; margin: 0; padding: 0; }

  .nm-work #nm-stage {
    max-width: 620px;
    margin: 0 auto;
  }

  .nm-work .meta {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.8rem;
    margin-bottom: 2rem;
  }

  .nm-work .intro-title {
    font-size: 22px;
    font-weight: normal;
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
  }

  .nm-work .intro-body {
    font-size: 14px;
    color: var(--dim);
    margin-bottom: 2rem;
    max-width: 500px;
    line-height: 1.75;
  }

  .nm-work .intro-body p + p { margin-top: 0.8rem; }

  .nm-work .card {
    border: 1px solid var(--ink);
    padding: 1.8rem 2rem;
    margin-bottom: 1.5rem;
  }

  .nm-work .card-fragment {
    font-size: 17px;
    line-height: 1.65;
    margin-bottom: 2rem;
    min-height: 3.5rem;
  }

  .nm-work .btn-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .nm-work button {
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.55rem 1.4rem;
    border: 1px solid var(--ink);
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition: background 80ms, color 80ms;
  }

  .nm-work button:hover { background: var(--ink); color: var(--paper); }

  .nm-work button.active-f { background: var(--ink); color: var(--paper); }
  .nm-work button.active-k { border-style: dashed; }

  .nm-work .nav-row {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-top: 1.5rem;
  }

  .nm-work .progress-note {
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .nm-work .result-section { margin-bottom: 2.5rem; }

  .nm-work .result-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dim);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.4rem;
    margin-bottom: 1.2rem;
  }

  .nm-work .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin-bottom: 1.5rem;
  }

  .nm-work .stat-cell {
    background: var(--paper);
    padding: 1rem;
    text-align: center;
  }

  .nm-work .stat-cell .s-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 0.4rem;
  }

  .nm-work .stat-cell .s-val { font-size: 26px; }

  .nm-work .norm-box {
    border: 1px solid var(--ink);
    padding: 1.5rem;
    font-size: 14px;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .nm-work .norm-box p + p { margin-top: 0.9rem; }

  .nm-work .rev-item {
    display: grid;
    grid-template-columns: 22px 1fr auto auto;
    gap: 8px;
    align-items: start;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--line);
    font-size: 12px;
  }

  .nm-work .rev-num { color: var(--dim); padding-top: 1px; }
  .nm-work .rev-text { line-height: 1.45; }

  .nm-work .rev-src {
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--dim);
    white-space: nowrap;
    padding-top: 2px;
  }

  .nm-work .rev-verdict {
    font-size: 10px;
    padding: 1px 5px;
    border: 1px solid;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .nm-work .verdict-F { border-color: var(--ink); color: var(--ink); }
  .nm-work .verdict-K { border-style: dashed; border-color: var(--dim); color: var(--dim); }

  .nm-work .colophon {
    font-size: 11px;
    color: var(--dim);
    margin-top: 3rem;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
    line-height: 1.85;
  }
</style>
