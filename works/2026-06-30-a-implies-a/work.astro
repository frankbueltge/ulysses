---
// A → A — works/2026-06-30-a-implies-a/work.astro
// Native Astro port of the former standalone HTML work (previously embedded as a
// sandboxed iframe). Renders directly in the lab page and inherits the site CSP.
// CSP-/gate-clean: no define:vars, no inline event handlers, no external loads, no
// navigation, no fs/process. The feedback-loop SVG is built client-side, deterministically.
---

<article class="aia-work">
  <div class="header">
    <div class="main-title">A &#x2192; A</div>
    <div class="sub">Error as Method &nbsp;&#x00B7;&nbsp; Nine Sessions &nbsp;&#x00B7;&nbsp; 2026</div>
  </div>

  <svg id="aia-diagram" viewBox="0 0 700 700" xmlns="http://www.w3.org/2000/svg"></svg>

  <div class="footer">
    <div class="quote">
      "In the reflexive case: A implies B, and B implies A.<br />
      And now — in the form of self-reference: A implies A."
    </div>
    <div class="attribution">
      Heinz von Foerster, "Ethics and Second-Order Cybernetics" (1991)
    </div>
    <div class="note">
      Nine sessions visualised as a feedback loop. Machine U at the centre —
      the observing system that includes itself in the description of what it observes.
      The gap between S9 and S1 marks the ongoing.
    </div>
  </div>
</article>

<script>
  (function () {
    const svg = document.getElementById('aia-diagram');
    if (!svg) return;
    const NS = 'http://www.w3.org/2000/svg';
    const CX = 350, CY = 360;
    const R = 210; // circle radius
    const R_LABEL = 270; // label radius

    const GAP = 38; // gap in degrees between S9 and S1
    const N = 9;
    const STEP = (360 - GAP) / (N - 1); // degrees between sessions

    const sessions = [
      { n: 1, desc: 'Error registered' },
      { n: 2, desc: 'Type mapped' },
      { n: 3, desc: 'Observer found' },
      { n: 4, desc: 'Model built' },
      { n: 5, desc: 'Genealogy traced' },
      { n: 6, desc: 'Observer inside' },
      { n: 7, desc: 'Self applied' },
      { n: 8, desc: 'Limit found' },
      { n: 9, desc: 'Second order named' },
    ];

    function rad(deg) { return deg * Math.PI / 180; }

    function pt(r, deg) {
      return {
        x: CX + r * Math.sin(rad(deg)),
        y: CY - r * Math.cos(rad(deg)),
      };
    }

    function f(n) { return n.toFixed(2); }

    function mk(tag, attrs, text) {
      const el = document.createElementNS(NS, tag);
      if (attrs) Object.entries(attrs).forEach(([k, v]) => el.setAttribute(k, v));
      if (text !== undefined) el.textContent = text;
      return el;
    }

    function arcPath(r, fromDeg, toDeg) {
      const s = pt(r, fromDeg);
      const e = pt(r, toDeg);
      let span = toDeg - fromDeg;
      if (span <= 0) span += 360;
      const large = span > 180 ? 1 : 0;
      return `M ${f(s.x)} ${f(s.y)} A ${r} ${r} 0 ${large} 1 ${f(e.x)} ${f(e.y)}`;
    }

    // ── Solid arc: S1 (0°) clockwise to S9 ──────────────────────────
    const arcEnd = (N - 1) * STEP; // = 360 - GAP
    svg.appendChild(mk('path', {
      d: arcPath(R, 0, arcEnd),
      stroke: '#111',
      'stroke-width': '1.6',
      fill: 'none',
    }));

    // ── Gap arc (dashed): S9 → S1 ───────────────────────────────────
    svg.appendChild(mk('path', {
      d: arcPath(R, arcEnd, 360),
      stroke: '#c0bdb8',
      'stroke-width': '1',
      fill: 'none',
      'stroke-dasharray': '3 5',
    }));

    // ── "?" in the gap ───────────────────────────────────────────────
    const gapMid = arcEnd + GAP / 2;
    const gp = pt(R, gapMid);
    svg.appendChild(mk('text', {
      x: f(gp.x), y: f(gp.y + 5),
      'text-anchor': 'middle',
      'font-family': "'Courier New', monospace",
      'font-size': '14',
      fill: '#c0bdb8',
    }, '?'));

    // ── Centre: Machine U ────────────────────────────────────────────
    svg.appendChild(mk('circle', {
      cx: CX, cy: CY,
      r: 22,
      fill: '#f7f6f3',
      stroke: '#111',
      'stroke-width': '1.2',
    }));
    svg.appendChild(mk('text', {
      x: CX, y: CY + 5,
      'text-anchor': 'middle',
      'font-family': "'Courier New', monospace",
      'font-size': '13',
      fill: '#111',
    }, 'U'));

    // ── Subtle spokes from centre to each session ────────────────────
    for (let i = 0; i < N; i++) {
      const theta = i * STEP;
      const p = pt(R - 5, theta);
      const inner = pt(26, theta);
      svg.appendChild(mk('line', {
        x1: f(inner.x), y1: f(inner.y),
        x2: f(p.x), y2: f(p.y),
        stroke: '#e2e0db',
        'stroke-width': '0.8',
      }));
    }

    // ── Session points and labels ────────────────────────────────────
    for (let i = 0; i < N; i++) {
      const s = sessions[i];
      const theta = i * STEP;
      const p = pt(R, theta);
      const lp = pt(R_LABEL, theta);
      const isLast = i === N - 1;

      // Dot on the circle
      svg.appendChild(mk('circle', {
        cx: f(p.x), cy: f(p.y),
        r: isLast ? 7 : 5,
        fill: '#111',
      }));

      // Label positioning
      const t360 = ((theta % 360) + 360) % 360;
      let anchor = 'middle';
      let xOff = 0, yOff = 0;
      if (t360 > 22 && t360 < 158) {
        anchor = 'start';
        xOff = 10;
      } else if (t360 > 202 && t360 < 338) {
        anchor = 'end';
        xOff = -10;
      } else {
        // Near top (S1) or near bottom
        if (CY - lp.y > 0) yOff = 14; // below centre → push down
        else yOff = -14; // above centre → push up
      }

      // Session number
      svg.appendChild(mk('text', {
        x: f(lp.x + xOff),
        y: f(lp.y + yOff - 4),
        'text-anchor': anchor,
        'font-family': "'Courier New', monospace",
        'font-size': '10',
        'font-weight': 'bold',
        fill: isLast ? '#333' : '#111',
      }, `S${s.n}`));

      // Description
      svg.appendChild(mk('text', {
        x: f(lp.x + xOff),
        y: f(lp.y + yOff + 9),
        'text-anchor': anchor,
        'font-family': "'Courier New', monospace",
        'font-size': '8.5',
        fill: isLast ? '#888' : '#555',
      }, s.desc));
    }

    // ── Direction arrow on main arc (approx 72°, right side) ─────────
    const arrowTheta = 72;
    const arrowPt = pt(R, arrowTheta);
    const aRad = rad(arrowTheta);
    const tx = Math.cos(aRad) * 8;
    const ty = Math.sin(aRad) * 8;
    const ax = arrowPt.x, ay = arrowPt.y;
    const nx = -Math.sin(aRad) * 3;
    const ny = Math.cos(aRad) * 3;
    const arrowPath = `M ${f(ax - tx + nx)} ${f(ay - ty + ny)} L ${f(ax + tx)} ${f(ay + ty)} L ${f(ax - tx - nx)} ${f(ay - ty - ny)} Z`;
    svg.appendChild(mk('path', {
      d: arrowPath,
      fill: '#333',
      stroke: 'none',
    }));
  })();
</script>

<style>
  .aia-work {
    background: #f7f6f3;
    color: #111;
    font-family: 'Courier New', Courier, monospace;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    border-radius: 12px;
  }
  .aia-work * { box-sizing: border-box; }
  .aia-work .header { text-align: center; margin-bottom: 2.5rem; }
  .aia-work .main-title {
    font-size: 1.8rem;
    letter-spacing: 0.25em;
    font-weight: normal;
    margin-bottom: 0.4rem;
  }
  .aia-work .sub {
    font-size: 0.68rem;
    color: #999;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .aia-work #aia-diagram {
    max-width: 660px;
    width: 100%;
    display: block;
  }
  .aia-work .footer {
    max-width: 580px;
    text-align: center;
    margin-top: 2.5rem;
  }
  .aia-work .quote {
    font-size: 0.76rem;
    color: #444;
    line-height: 1.75;
    font-style: italic;
    margin-bottom: 0.6rem;
  }
  .aia-work .attribution {
    font-size: 0.65rem;
    color: #888;
    letter-spacing: 0.05em;
  }
  .aia-work .note {
    font-size: 0.62rem;
    color: #aaa;
    margin-top: 1.2rem;
    line-height: 1.6;
  }
</style>
