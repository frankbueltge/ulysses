---
// Named, the Glitch Is No More — works/2026-07-07-named-the-glitch/work.astro
// A real databend. Rosa Menkman's own manifesto sentences are encoded to their
// actual UTF-8 byte stream and rastered to a canvas at a chosen row width. The
// "flow" control rewraps the identical bytes: break the reading order and meaning
// shears into byte-noise ("a break from a flow of expectations"). Clicking a
// region NAMES those bytes back into legible text — and a named region stays
// resolved. Enacts Menkman: "once I named it, the momentum -the glitch- is no
// more", and her normalization thesis (recognition domesticates the glitch out
// of existence). The error mechanism runs for real; nothing is simulated.
import work from './data.json'

const text: string = work.quotes.join('  |  ')
const payload: string = JSON.stringify({ text })
---

<article class="gl-work">

  <header>
    <h1>Named, the Glitch Is No More</h1>
    <div class="sub">databend · UTF-8 byte raster · substrate: the Glitch Studies Manifesto</div>
    <div class="epi">&ldquo;{work.epigraph}&rdquo;</div>
    <div class="epi-src">— {work.epigraph_source}</div>
  </header>

  <div class="stage">
    <canvas id="gl-canvas" width="600" height="200"></canvas>
    <div class="caption">
      The same real bytes, read at the wrong stride. A text is a linear flow; every
      2-D raster of it is already a break from that flow. Move the reading width and
      the identical data shears — meaning becomes byte-noise. This is databending, the
      method Menkman names: read data through the wrong flow and the substrate leaks.
    </div>
  </div>

  <div class="controls">
    <label class="ctl">
      <span class="ctl-lbl">reading width (the expected flow)</span>
      <input type="range" id="gl-stride" min="9" max="96" value="37" step="1" />
      <span id="gl-stride-val" class="ctl-num">37</span>
    </label>
    <div class="btns">
      <button type="button" id="gl-normalize">normalize all &rarr; text</button>
      <button type="button" id="gl-reglitch">re-glitch</button>
    </div>
  </div>

  <div class="readout-wrap">
    <div id="gl-readout" class="readout">click any region to name it — naming restores it to text</div>
    <div id="gl-progress" class="progress">glitch: 100% &middot; named: 0%</div>
  </div>

  <div class="flow">
    <div class="flow-lbl">the expected flow (what the bytes say, read in order):</div>
    {work.quotes.map((q: string) => <p class="flow-q">{q}</p>)}
  </div>

  <footer>
    <p>{work.source}</p>
    <p class="fnote">{work.note}</p>
    <p class="sig">
      Deterministic: the same text and width give the same raster (seed = the text itself).<br>
      Glitch is a break from a flow of expectations, and it dies when it is named.<br>
      Ulysses — Error as Method — 2026-07-07
    </p>
  </footer>

  <script type="application/json" id="gl-data" set:html={payload}></script>

</article>

<script>
  interface Payload { text: string }

  const dataEl = document.getElementById('gl-data')
  const parsed: Payload = JSON.parse(dataEl?.textContent || '{"text":""}')
  const text: string = parsed.text
  const bytes: Uint8Array = new TextEncoder().encode(text)
  const N: number = bytes.length
  const named: Uint8Array = new Uint8Array(N)

  const canvas = document.querySelector('#gl-canvas') as HTMLCanvasElement | null
  const ctx = canvas ? canvas.getContext('2d') : null
  const strideInput = document.querySelector('#gl-stride') as HTMLInputElement | null
  const strideVal = document.querySelector('#gl-stride-val') as HTMLElement | null
  const readout = document.querySelector('#gl-readout') as HTMLElement | null
  const progress = document.querySelector('#gl-progress') as HTMLElement | null
  const normBtn = document.querySelector('#gl-normalize') as HTMLButtonElement | null
  const reBtn = document.querySelector('#gl-reglitch') as HTMLButtonElement | null

  const MAXW = 600
  const SPACE = 32

  function stride(): number {
    return strideInput ? parseInt(strideInput.value, 10) : 37
  }

  function cellSize(s: number): number {
    return Math.max(4, Math.min(20, Math.floor(MAXW / s)))
  }

  // byte value -> lightness, monotonic; space (32) darkest, '~' (126) lightest
  function lightness(b: number): number {
    const t = Math.min(1, Math.max(0, (b - SPACE) / 94))
    return Math.round(18 + 208 * t)
  }

  function draw(): void {
    if (!ctx || !canvas) return
    const s = stride()
    const cell = cellSize(s)
    const rows = Math.ceil(N / s)
    canvas.width = s * cell
    canvas.height = rows * cell
    ctx.fillStyle = '#050505'
    ctx.fillRect(0, 0, canvas.width, canvas.height)
    ctx.textAlign = 'center'
    ctx.textBaseline = 'middle'
    const glyph = `${Math.max(6, cell - 2)}px "Courier New", monospace`
    for (let i = 0; i < N; i++) {
      const col = i % s
      const row = Math.floor(i / s)
      const x = col * cell
      const y = row * cell
      const b = bytes[i]
      if (named[i]) {
        // resolved: the byte named back into its character, legible
        ctx.fillStyle = '#0d130d'
        ctx.fillRect(x, y, cell, cell)
        ctx.fillStyle = '#79c079'
        ctx.font = glyph
        const ch = b === SPACE ? '·' : String.fromCharCode(b)
        ctx.fillText(ch, x + cell / 2, y + cell / 2 + 0.5)
      } else {
        // glitch: the raw byte as a grey cell
        const l = lightness(b)
        ctx.fillStyle = `rgb(${l},${l},${l})`
        ctx.fillRect(x, y, cell - 1, cell - 1)
      }
    }
  }

  function updateProgress(): void {
    if (!progress) return
    let count = 0
    for (let i = 0; i < N; i++) count += named[i]
    const pct = Math.round((count / N) * 100)
    progress.textContent = `glitch: ${100 - pct}% · named: ${pct}%`
    if (pct >= 100) {
      progress.textContent = 'the glitch is no more — it is only text now.'
    }
  }

  function nameRange(a: number, b: number): void {
    for (let k = a; k <= b; k++) named[k] = 1
  }

  function nameAt(clientX: number, clientY: number): void {
    if (!canvas) return
    const s = stride()
    const cell = cellSize(s)
    const rect = canvas.getBoundingClientRect()
    const mx = (clientX - rect.left) * (canvas.width / rect.width)
    const my = (clientY - rect.top) * (canvas.height / rect.height)
    const col = Math.floor(mx / cell)
    const row = Math.floor(my / cell)
    const i = row * s + col
    if (i < 0 || i >= N || col >= s) return
    // expand to the word this byte belongs to (space-delimited)
    let a = i
    let z = i
    while (a > 0 && bytes[a - 1] !== SPACE) a--
    while (z < N - 1 && bytes[z + 1] !== SPACE) z++
    nameRange(a, z)
    const word = text.slice(a, z + 1)
    if (readout) readout.textContent = `named: “${word}”  — and so it is no longer a glitch there.`
    draw()
    updateProgress()
  }

  function hoverAt(clientX: number, clientY: number): void {
    if (!canvas || !readout) return
    const s = stride()
    const cell = cellSize(s)
    const rect = canvas.getBoundingClientRect()
    const mx = (clientX - rect.left) * (canvas.width / rect.width)
    const my = (clientY - rect.top) * (canvas.height / rect.height)
    const col = Math.floor(mx / cell)
    const row = Math.floor(my / cell)
    const i = row * s + col
    if (i < 0 || i >= N || col >= s) return
    if (named[i]) return
    const b = bytes[i]
    const ch = b === SPACE ? 'space' : `'${String.fromCharCode(b)}'`
    readout.textContent = `byte ${i}: value ${b} — unnamed (${ch}). click to name it.`
  }

  if (strideInput) {
    strideInput.addEventListener('input', () => {
      if (strideVal) strideVal.textContent = strideInput.value
      draw()
    })
  }
  if (canvas) {
    canvas.addEventListener('click', (e: MouseEvent) => nameAt(e.clientX, e.clientY))
    canvas.addEventListener('pointermove', (e: PointerEvent) => hoverAt(e.clientX, e.clientY))
  }
  if (normBtn) {
    normBtn.addEventListener('click', () => {
      named.fill(1)
      if (readout) {
        readout.textContent =
          'normalized. "What was a glitch 10 years ago is not a glitch anymore." The break, fully named, is only a commodity: text.'
      }
      draw()
      updateProgress()
    })
  }
  if (reBtn) {
    reBtn.addEventListener('click', () => {
      named.fill(0)
      if (readout) readout.textContent = 'click any region to name it — naming restores it to text'
      draw()
      updateProgress()
    })
  }

  draw()
  updateProgress()
</script>

<style>
  .gl-work {
    background: #050505;
    font-family: 'Courier New', Courier, monospace;
    color: #9a9a9a;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.6rem 1.4rem 3.2rem;
  }

  .gl-work *,
  .gl-work *::before,
  .gl-work *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .gl-work header {
    text-align: center;
    margin-bottom: 2rem;
    max-width: 640px;
  }

  .gl-work h1 {
    font-size: 0.9rem;
    font-weight: normal;
    letter-spacing: 0.42em;
    color: #cfcfcf;
    text-transform: uppercase;
  }

  .gl-work .sub {
    font-size: 0.5rem;
    letter-spacing: 0.28em;
    color: #2b2b2b;
    margin-top: 0.5rem;
    text-transform: uppercase;
  }

  .gl-work .epi {
    font-size: 0.8rem;
    line-height: 1.6;
    color: #7a7a7a;
    margin-top: 1.5rem;
    font-style: italic;
  }

  .gl-work .epi-src {
    font-size: 0.44rem;
    letter-spacing: 0.08em;
    color: #2a2a2a;
    margin-top: 0.5rem;
  }

  .gl-work .stage {
    width: 100%;
    max-width: 620px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .gl-work canvas {
    max-width: 100%;
    height: auto;
    image-rendering: pixelated;
    border: 1px solid #161616;
    cursor: crosshair;
    background: #050505;
  }

  .gl-work .caption {
    font-size: 0.58rem;
    line-height: 1.85;
    color: #565656;
    margin-top: 0.9rem;
    max-width: 600px;
    text-align: left;
  }

  .gl-work .controls {
    width: 100%;
    max-width: 600px;
    margin-top: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .gl-work .ctl {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.5rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6a6a6a;
  }

  .gl-work .ctl-lbl {
    flex: 0 0 auto;
  }

  .gl-work input[type='range'] {
    flex: 1 1 auto;
    accent-color: #79c079;
    height: 2px;
  }

  .gl-work .ctl-num {
    flex: 0 0 2.2em;
    text-align: right;
    color: #a9a9a9;
  }

  .gl-work .btns {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .gl-work button {
    background: #0c0c0c;
    border: 1px solid #232323;
    color: #8a8a8a;
    font-family: inherit;
    font-size: 0.48rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.5rem 0.9rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .gl-work button:hover {
    border-color: #79c079;
    color: #cfcfcf;
  }

  .gl-work .readout-wrap {
    width: 100%;
    max-width: 600px;
    margin-top: 1.4rem;
    text-align: center;
  }

  .gl-work .readout {
    font-size: 0.62rem;
    line-height: 1.6;
    color: #79c079;
    min-height: 2.4em;
    letter-spacing: 0.03em;
  }

  .gl-work .progress {
    font-size: 0.48rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #3a3a3a;
    margin-top: 0.5rem;
  }

  .gl-work .flow {
    width: 100%;
    max-width: 600px;
    margin-top: 2.4rem;
    border-top: 1px solid #161616;
    padding-top: 1.4rem;
  }

  .gl-work .flow-lbl {
    font-size: 0.46rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #333;
    margin-bottom: 0.9rem;
  }

  .gl-work .flow-q {
    font-size: 0.72rem;
    line-height: 1.7;
    color: #6f6f6f;
    margin-bottom: 0.7rem;
  }

  .gl-work footer {
    margin-top: 2.6rem;
    max-width: 600px;
    font-size: 0.46rem;
    line-height: 1.9;
    color: #2f2f2f;
    text-align: center;
    letter-spacing: 0.05em;
  }

  .gl-work footer .fnote {
    margin-top: 0.6rem;
    color: #262626;
  }

  .gl-work footer .sig {
    margin-top: 1.1rem;
    color: #3a3a3a;
    letter-spacing: 0.12em;
    line-height: 2.1;
  }
</style>
