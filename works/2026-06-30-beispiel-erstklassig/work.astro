---
// works/2026-06-30-beispiel-erstklassig/work.astro
// Reference skeleton: reads a committed dataset at build time, renders statically.
// No layout import — the gate provides route and layout.
import klimaDaten from '@/data/climate/global-temp-anomalies.json'

// Last 12 years from the archive (fully measured years and partial years)
const letzteJahre = klimaDaten.years.slice(-12)

// Annual mean from non-null monthly values
function jahresmittel(monate: (number | null)[]): number {
  const gueltig = monate.filter((m): m is number => m !== null)
  if (gueltig.length === 0) return 0
  return gueltig.reduce((s, v) => s + v, 0) / gueltig.length
}

const punkte = letzteJahre.map(({ year, months }) => ({
  year,
  mittel: jahresmittel(months),
  monate: months.filter((m) => m !== null).length,
}))

const quelle = klimaDaten.meta
---

<section class="font-mono text-sm">
  <h1 class="text-2xl font-bold mb-1">Example — first-class</h1>
  <p class="text-fg-muted mb-4">
    Build-time data from the climate archive, no network, deterministic.<br />
    Annual mean temperature anomaly (°C) — last 12 years.
  </p>

  <table class="w-full border-collapse">
    <thead>
      <tr class="border-b border-fg-muted/30">
        <th class="text-left pr-6 pb-1">Year</th>
        <th class="text-right pr-6 pb-1">Anomaly (°C)</th>
        <th class="text-right pb-1">Months measured</th>
      </tr>
    </thead>
    <tbody>
      {punkte.map(({ year, mittel, monate }) => (
        <tr class="border-b border-fg-muted/10">
          <td class="pr-6 py-0.5">{year}</td>
          <td class="text-right pr-6 py-0.5">{mittel.toFixed(2)}</td>
          <td class="text-right py-0.5">{monate}/12</td>
        </tr>
      ))}
    </tbody>
  </table>

  <p class="mt-4 text-xs text-fg-muted">
    Source: {quelle.source}<br />
    Baseline: {quelle.baseline} · As of: {quelle.retrieved}
  </p>
</section>
