    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .void-work .station {
    border-left: 1px solid #161616;
    padding-left: 1.3rem;
  }

  .void-work .lbl {
    font-size: 0.48rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin-bottom: 0.38rem;
    opacity: 0.75;
  }

  .void-work .lbl-c1 { color: #9a5f1e; }
  .void-work .lbl-c2 { color: #1e7a7a; }
  .void-work .lbl-c3 { color: #2a7a2a; }
  .void-work .lbl-c4 { color: #5a3a8a; }

  .void-work .src {
    font-size: 0.43rem;
    color: #1d1d1d;
    margin-bottom: 0.7rem;
    letter-spacing: 0.07em;
  }

  .void-work .qt {
    font-size: 0.83rem;
    line-height: 1.8;
    color: #999;
    letter-spacing: 0.018em;
  }

  .void-work .vi {
    transition: color 0.08s ease;
    cursor: default;
  }

  .void-work footer {
    margin-top: 3rem;
    max-width: 640px;
    font-size: 0.43rem;
    color: #1c1c1c;
    text-align: center;
    letter-spacing: 0.14em;
    line-height: 2.4;
  }

  .void-work #void-ctrl {
    margin-top: 2.2rem;
    font-size: 0.42rem;
    letter-spacing: 0.3em;
    color: #191919;
    cursor: pointer;
    transition: color 0.25s;
    user-select: none;
  }

  .void-work #void-ctrl:hover { color: #555; }
</style>
